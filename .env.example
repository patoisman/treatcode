# Treatcode V2 — environment variables
# Copy this file to `.env.local` and fill in the values.
# All client-side vars MUST be prefixed with VITE_ to be exposed to the app.
# Never commit real values — `.env*` is gitignored.

# Supabase project URL (Project Settings → API)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase anonymous/publishable key (Project Settings → API).
# Safe to expose in the browser — RLS enforces access control server-side.
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# Google Identity Services OAuth client ID (Google Cloud Console → Credentials).
# The deployed domain must be added to "Authorized JavaScript origins".
VITE_GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
